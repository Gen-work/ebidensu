# --- Per-operator runtime state (VerifyTool creates/updates these at run time; never commit) ---
verify_session.json
verify_config.json
status/
snap/
bk/
mapping_*.csv
*.bak

# --- Personal/local backup copies of tracked files (e.g. VerifyConfig_bk.psd1) --
# never intended as the authoritative source; commit examples under docs/ or
# examples/ instead if a reference copy is actually needed. ---
*_bk.ps1
*_bk.psd1
*_bk.json
*.bak.ps1
*.bak.psd1

# --- IDE / workspace state (Eclipse-family workspaces carry logs with hostnames and user paths) ---
.metadata/
.project
.vscode/
.idea/

# --- Claude Code local state (worktrees, per-user settings) ---
.claude/

# --- Captured evidence / templates: screenshots and workbooks may show client pages ---
mark_templates/*.png
*.xlsx
*.xlsm
*.zip
*.log
